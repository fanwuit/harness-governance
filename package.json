{
  "scripts": {
    "test": "node --test harness-visualization/tests/*.test.mjs autonomous-ready-loop/tests/*.test.mjs harness-engineering/tests/*.test.mjs planning-with-files/tests/*.test.mjs governed-implementation-entry/tests/*.test.mjs",
    "check:routing": "python harness-engineering/scripts/check-routing-guardrails.py",
    "check:packets": "node harness-engineering/scripts/check-change-packet.mjs",
    "check:entry-record": "node governed-implementation-entry/scripts/check-entry-record.mjs governed-implementation-entry/tests/fixtures/valid-entry-record.md",
    "check:fast": "npm run check:routing && node --test harness-engineering/tests/governance-docs.test.mjs governed-implementation-entry/tests/check-entry-record.test.mjs",
    "check:governance": "npm run check:routing && node --test harness-engineering/tests/*.test.mjs governed-implementation-entry/tests/*.test.mjs planning-with-files/tests/*.test.mjs",
    "check:all": "npm run check:routing && npm test && npm run check:packets && npm run check:entry-record"
  }
}
